# .env.example — copy to .env and fill in your values
# DO NOT commit .env — it contains real credentials

# === ELASTICSEARCH =====================================================
ELASTICSEARCH_URL=https://your-project.es.us-central1.gcp.elastic.cloud:443
ELASTICSEARCH_API_KEY=your_elasticsearch_api_key_here
ELASTICSEARCH_INDEX_PREFIX=cosecha_urbana

# === LLM - GROQ (active, free tier available) ==========================
# Get key at: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_TEMPERATURE=0.1
GROQ_MAX_TOKENS=1024

# === LLM - Anthropic (optional fallback) ================================
# Set LLM_MODEL=anthropic to use Claude instead of Groq
ANTHROPIC_API_KEY=
LLM_MODEL=groq
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=1024

# === FASTAPI =============================================================
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=true
API_SECRET_KEY=change-this-in-production
CORS_ORIGINS=["http://localhost:3000","http://localhost:5601","http://localhost:8000"]

# === KIBANA ==============================================================
# Find your Kibana URL at: https://cloud.elastic.co -> your project -> Kibana endpoint
# Example: https://your-project.kb.us-central1.gcp.elastic.cloud
KIBANA_URL=https://your-project.kb.us-central1.gcp.elastic.cloud

# === NOTIFICATIONS - SLACK =============================================
#
# OPTION A: Slack Incoming Webhook (5 min setup, no bot token needed)
#   1. https://api.slack.com/apps -> Create App -> Incoming Webhooks -> ON
#   2. Add Webhook to Workspace -> select channel -> copy URL
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# OPTION B: Kibana Connector (Elastic-native, extra hackathon points)
#   1. Set SLACK_WEBHOOK_URL above
#   2. Run: python scripts/setup_kibana_connector.py
#   3. Copy the connector ID printed by the script
KIBANA_SLACK_CONNECTOR_ID=

# === AGENT CONFIGURATION ================================================
AGENT_MAX_STEPS=10
AGENT_TIMEOUT_SECONDS=120
MAX_DISTANCE_KM=15
FOOD_URGENCY_THRESHOLD_HOURS=4

# === LOGGING =============================================================
LOG_LEVEL=INFO
LOG_FORMAT=console
